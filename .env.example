# Copy this file to .env.local and fill in your real keys.
# Never commit .env.local to Git.

# Required API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# Optional provider base URLs.
# Useful for third-party relays or OpenAI-compatible gateways.
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
GEMINI_BASE_URL=
DEEPSEEK_BASE_URL=
XAI_BASE_URL=

# Optional search key for DeepSeek external search augmentation.
# If left empty, the smoke test falls back to public DuckDuckGo search.
TAVILY_API_KEY=

# Optional exact model IDs for the low-cost smoke test.
# Replace these with the exact model IDs shown in each provider console if needed.
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_MODEL=claude-haiku-4-5
GEMINI_MODEL=gemini-3.1-flash-lite-preview
DEEPSEEK_MODEL=deepseek-chat
XAI_MODEL=grok-4
